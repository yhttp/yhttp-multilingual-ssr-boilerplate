[flake8]
ignore = W503
exclude = 
	build
	makomodules

per-file-ignores =
	boilerplate/__init__.py: F401
	boilerplate/**/__init__.py: F401
	boilerplate/**/routes.py: F811
	boilerplate/**/routes/*.py: F811
	boilerplate/routes.py: F811
	boilerplate/rollup.py: F401, F811, E402
    tests/conftest.py: F401, F811
